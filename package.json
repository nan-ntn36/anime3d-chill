{
  "name": "anime3d-chill",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "admin"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "server:dev": "turbo run dev --filter=@anime3d-chill/server",
    "client:dev": "turbo run dev --filter=@anime3d-chill/client",
    "admin:dev": "turbo run dev --filter=@anime3d-chill/admin"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
